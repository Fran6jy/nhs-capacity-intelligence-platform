# --- LLM ---
LLM_PROVIDER=anthropic         # anthropic | openrouter | openai | azure | ollama
# --- Anthropic (Claude) — default provider ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# --- OpenRouter (OpenAI-compatible gateway to many models) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# --- OpenAI (optional) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Azure OpenAI (optional) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=

# --- Storage ---
# Offline build engine for the gold layer (medallion). Published into Postgres.
WAREHOUSE_PATH=./data/gold/warehouse.duckdb
BRONZE_PATH=./data/raw
SILVER_PATH=./data/processed
GOLD_PATH=./data/gold

# --- Database (PostgreSQL system-of-record; managed cloud or local) ---
DATABASE_URL=postgresql+psycopg2://nhs:password@localhost:5432/nhs_warehouse

# --- API ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- App ---
LOG_LEVEL=INFO
APP_ENV=local
